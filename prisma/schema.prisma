generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  avatar       String?
  plan         String   @default("free") // free, starter, pro
  credits      Int      @default(5)
  onboarded    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads        Lead[]
  preferences  Preference?
  notifications Notification[]
  campaigns    ProspectionCampaign[]
  creditTransactions CreditTransaction[]
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  business        String?
  sector          String?
  city            String?
  phone           String?
  whatsapp        String?
  email           String?
  address         String?
  source          String   @default("maps") // maps, facebook, instagram, linkedin
  stage           String   @default("nouveau") // nouveau, contacte, en_discussion, a_relancer, gagne, perdu
  notes           String?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  contactCount    Int      @default(0)
  aiSuggestion    String?  // last AI-generated suggestion
  score           Int      @default(50) // lead score 0-100
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  contacts        ContactHistory[]
}

model ContactHistory {
  id          String   @id @default(cuid())
  type        String   // appel, whatsapp, email, visite, note
  content     String?  // message content or note text
  aiGenerated Boolean  @default(false)
  leadId      String
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Preference {
  id           String   @id @default(cuid())
  sectors      String   @default("")
  cities       String   @default("")
  businessType String   @default("")
  userId       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model Notification {
  id           String   @id @default(cuid())
  type         String   @default("new_leads") // new_leads, system, subscription, follow_up, relance, ai_suggestion
  title        String
  message      String
  read         Boolean  @default(false)
  leadId       String?
  userId       String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin") // super_admin, admin, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProspectionCampaign {
  id          String   @id @default(cuid())
  productName String
  images      String   @default("") // comma-separated URLs
  // Legacy single-city field kept for backward compat with existing rows.
  city        String   @default("")
  // New: comma-separated list of locations (e.g. "CM:Douala,CM:Yaounde,CI::all" or
  // "CM:all" to target a whole country). The form writes here; city is mirrored
  // from the first entry for backward-compatible admin views.
  locations   String   @default("") // comma-separated "ISO2:CityName" entries, ":all" = whole country
  status      String   @default("active") // active, completed, paused
  leadsFound  Int      @default(0)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model AppSettings {
  id                    String   @id @default(cuid())
  key                   String   @unique
  value                 String
  description           String?
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // create, update, delete, login, export, bulk
  entity      String   // user, lead, campaign, notification, settings, credit, admin
  entityId    String?
  adminEmail  String
  details     String?  // JSON string with change details
  ip          String?
  createdAt   DateTime @default(now())
}

/// A configurable credit rule — how many credits each value-add action costs.
/// Admin can CRUD these rules via /admin/api/credit-rules.
model CreditRule {
  id              String   @id @default(cuid())
  /// Stable action key, e.g. "prospection.launch", "ai.draft", "lead.export".
  /// Used by the code to look up the cost; never changes after creation.
  action          String   @unique
  /// Human-readable label shown in admin UI and user-facing breakdowns.
  label           String
  /// Cost in credits. 0 = free. Negative = grants credits (rare; used for bonuses).
  cost            Int      @default(1)
  /// Longer description for admin tooltip.
  description     String?
  /// If false, the rule is inactive and the action is free.
  enabled         Boolean  @default(true)
  /// Free quota per day before credits are deducted. 0 = no free quota.
  freeQuotaPerDay Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Every credit movement is recorded here for audit and user transparency.
/// Both user-triggered (action cost) and admin-triggered (grant/set) ops.
model CreditTransaction {
  id             String   @id @default(cuid())
  /// Positive = credit added, negative = credit deducted.
  amount         Int
  /// Balance after this transaction (snapshot for fast user-side display).
  balanceAfter   Int
  /// The action key from CreditRule, or a synthetic key for admin grants:
  /// "admin.grant", "admin.set", "purchase.pack", "signup.bonus".
  action         String
  /// Human-readable label (denormalized from CreditRule.label at the time of
  /// the transaction, so old transactions stay accurate even if the rule is
  /// later edited).
  label          String
  /// Optional reference to the entity that triggered the transaction
  /// (e.g. campaignId for prospection.launch, leadId for ai.draft).
  entityId       String?
  /// Optional idempotency token. If two requests arrive with the same token
  /// within a short window, only the first one applies the credit movement.
  idempotencyKey String?
  /// Optional note (e.g. admin reason for granting credits).
  note           String?
  userId         String
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
