generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  avatar       String?
  plan         String   @default("free") // free, starter, pro
  credits      Int      @default(5)
  onboarded    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads        Lead[]
  preferences  Preference?
  notifications Notification[]
  campaigns    ProspectionCampaign[]
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  business        String?
  sector          String?
  city            String?
  phone           String?
  whatsapp        String?
  email           String?
  address         String?
  source          String   @default("maps") // maps, facebook, instagram, linkedin
  stage           String   @default("nouveau") // nouveau, contacte, en_discussion, a_relancer, gagne, perdu
  notes           String?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  contactCount    Int      @default(0)
  aiSuggestion    String?  // last AI-generated suggestion
  score           Int      @default(50) // lead score 0-100
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  contacts        ContactHistory[]
}

model ContactHistory {
  id          String   @id @default(cuid())
  type        String   // appel, whatsapp, email, visite, note
  content     String?  // message content or note text
  aiGenerated Boolean  @default(false)
  leadId      String
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Preference {
  id           String   @id @default(cuid())
  sectors      String   @default("")
  cities       String   @default("")
  businessType String   @default("")
  userId       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model Notification {
  id           String   @id @default(cuid())
  type         String   @default("new_leads") // new_leads, system, subscription, follow_up, relance, ai_suggestion
  title        String
  message      String
  read         Boolean  @default(false)
  leadId       String?
  userId       String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin") // super_admin, admin, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProspectionCampaign {
  id          String   @id @default(cuid())
  productName String
  images      String   @default("") // comma-separated URLs
  city        String
  status      String   @default("active") // active, completed, paused
  leadsFound  Int      @default(0)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model AppSettings {
  id                    String   @id @default(cuid())
  key                   String   @unique
  value                 String
  description           String?
  updatedAt             DateTime @updatedAt
}
